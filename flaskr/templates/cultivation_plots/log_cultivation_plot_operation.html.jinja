{% extends "layout.html.jinja" %}

{% import 'macros.html.jinja' as macros %}

{% block title %}

Cultivation plot > {{ cultivation_plot.name }} > Log operation

{% endblock %}

{% block content %}

<main>

  <div class="fw-bold text-center fs-4">{{ cultivation_plot.name }}</div>
  <div class="w-25 mx-auto">
    {{ macros.dirt_cube() }}
  </div>
  <div class="fst-italic text-center">{{ cultivation_plot.crop }}</div>

  <h1 class="text-center my-4">Log operation</h1>

  <form class="border rounded p-4" method="POST" action="{{ url_for('cultivation_plots.log_cultivation_plot_operation', id=cultivation_plot['id']) }}">

    <div class="mb-3">
      <label class="form-label" for="number_of_plants">Number of plants</label>
      <input class="form-control" type="number" min="-{{ cultivation_plot.number_of_plants }}" name="number_of_plants" id="number_of_plants" value="0">
      <div id="number_of_plants_help" class="form-text">Negative numbers are allowed</div>
    </div>

    <div class="mb-3">
      <label class="form-label" for="water_spent">Water spent (L) <span class="text-danger">*</span></label>
      <input class="form-control" type="number" value="0.00" step="0.01" name="water_spent" min="0" id="water_spent" required>
    </div>

    <div class="mb-5">
      <label class="form-label" for="harvest">Harvest (kg) <span class="text-danger">*</span></label>
      <input class="form-control" type="number" value="0.00" step="0.01" min="0" name="harvest" id="harvest" required>
    </div>

    <div class="d-grid">
      <button type="submit" class="btn btn-primary">Log</button>
    </div>
  </form>
</main>

{% endblock %}